generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  name      String
  company   String?
  role      String   @default("user") // "user" | "admin"
  apiKey    String   @unique @default(uuid()) @map("api_key")
  
  // Subscription Fields
  isPremium      Boolean   @default(false) @map("is_premium")
  proStartedAt   DateTime? @map("pro_started_at")
  proExpiresAt   DateTime? @map("pro_expires_at")
  trialEndsAt    DateTime? @map("trial_ends_at")
  agentLimit     Int       @default(1) @map("agent_limit") // 1 for trial, 10 for pro

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agents   Agent[]
  payments Payment[]
  couponUsages CouponUsage[]
  @@map("users")
}

model Agent {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  companyName    String?  @map("company_name")
  integrationType String  @default("both") @map("integration_type")
  socialLinks    Json?    @map("social_links")
  systemPrompt   String   @map("system_prompt") @db.Text
  websiteUrl     String?  @map("website_url")
  tone           String   @default("friendly")
  model          String   @default("gpt-4o-mini")
  webhookUrl     String?  @map("webhook_url")
  collectLeads   Boolean  @default(false) @map("collect_leads")
  allowedDomains String?  @map("allowed_domains")
  primaryColor    String   @default("#6C5CE7") @map("primary_color")
  secondaryColor  String?  @map("secondary_color")
  useGradient     Boolean  @default(false) @map("use_gradient")
  widgetTheme     String   @default("bubble") @map("widget_theme")
  welcomeMessage  String   @default("Hi there! How can I help you today?") @map("welcome_message")
  botAvatar       String?  @map("bot_avatar")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  leads         Lead[]
  webhookLogs   WebhookLog[]
  analytics     Analytics[]
  @@map("agents")
}

model Payment {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  trxId       String   @unique @map("trx_id")
  amount      Float
  method      String   // "BKASH" | "NAGAD"
  status      String   @default("PENDING") // "PENDING" | "APPROVED" | "DECLINED"
  plan        String   @default("PRO_MONTHLY")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("payments")
}

model Analytics {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  type      String   // "view" or "click"
  createdAt DateTime @default(now()) @map("created_at")

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@map("analytics")
}

model Conversation {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  sessionId String   @map("session_id")
  userInfo  Json?    @map("user_info")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]
  @@unique([agentId, sessionId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@map("messages")
}

model Lead {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  sessionId String?  @map("session_id")
  name      String?
  email     String?
  phone     String?
  source    String?
  createdAt DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@map("leads")
}

model WebhookLog {
  id         String   @id @default(uuid())
  agentId    String   @map("agent_id")
  sessionId  String?  @map("session_id")
  payload    Json
  statusCode Int?     @map("status_code")
  response   String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@map("webhook_logs")
}

model Settings {
  id        String   @id @default("global")
  
  // AI Config
  aiModel   String   @default("openai-gpt-oss-120b") @map("ai_model")
  aiBaseUrl String?  @map("ai_base_url")
  aiApiKey  String?  @map("ai_api_key")
  
  // Payment Config
  bkashNumber String? @map("bkash_number")
  nagadNumber String? @map("nagad_number")

  // Auth Config
  googleClientId     String? @map("google_client_id")
  googleClientSecret String? @map("google_client_secret")

  // Plugin Config
  pluginZipPath String? @map("plugin_zip_path")
  pluginVersion String? @map("plugin_version") @default("1.0.4")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model Coupon {
  id             String        @id @default(uuid())
  code           String        @unique
  discount       Float         // 10.0 for 10% or 500 for 500৳
  type           String        @default("PERCENT") // "PERCENT" | "FLAT"
  durationMonths Int           @default(1) @map("duration_months")
  isActive       Boolean       @default(true) @map("is_active")
  maxUses        Int?          @map("max_uses")
  usedCount      Int           @default(0) @map("used_count")
  expiresAt      DateTime?     @map("expires_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  usages         CouponUsage[]
  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String   @map("coupon_id")
  userId    String   @map("user_id")
  usedAt    DateTime @default(now()) @map("used_at")

  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("coupon_usages")
}

